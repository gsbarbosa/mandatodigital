{
  "name": "mandato-digital",
  "version": "0.1.0",
  "description": "MVP interno do Mandato Digital para onboarding, geracao e revisao de conteudo politico.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "sentinel:quality-eval": "node scripts/sentinel-quality-eval.cjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "playwright:install": "playwright install --with-deps chromium",
    "db:reset": "node scripts/reset-database.mjs",
    "db:reset:confirm": "node scripts/reset-database.mjs --confirm",
    "firebase:rules:deploy": "firebase deploy --only firestore:rules,storage",
    "firebase:indexes:deploy": "firebase deploy --only firestore:indexes",
    "sync:logo": "node scripts/sync-brand-logo.mjs",
    "predev": "node scripts/sync-brand-logo.mjs",
    "prebuild": "node scripts/sync-brand-logo.mjs",
    "deploy:firebase": "firebase deploy --only apphosting",
    "firebase:secrets:guide": "node scripts/firebase-secrets-guide.mjs",
    "firebase:secrets:apply": "node scripts/firebase-secrets-guide.mjs --apply",
    "env:pull": "node scripts/pull-remote-env.mjs"
  },
  "keywords": [
    "nextjs",
    "ia",
    "comunicacao-politica"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "form-data": "^4.0.5",
    "next": "^16.2.6",
    "pdfkit": "^0.19.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.17.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^25.9.1",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
