{
  "name": "mandato-digital",
  "version": "0.1.0",
  "description": "MVP interno do Mandato Digital para onboarding, geracao e revisao de conteudo politico.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:argil": "npm run build && PW_FORCE_FRESH_SERVER=1 PW_DEV_PORT=3010 PW_USE_START=1 playwright test tests/e2e/argil-video-flow.spec.ts",
    "test:e2e:headed": "playwright test --headed",
    "playwright:install": "playwright install --with-deps chromium",
    "db:reset": "node scripts/reset-database.mjs",
    "db:reset:confirm": "node scripts/reset-database.mjs --confirm",
    "db:migrate:owner-user-id": "node scripts/apply-owner-user-id-migration.mjs",
    "db:migrate:creative-projects": "node scripts/apply-creative-projects-migration.mjs",
    "db:migrate:sentinel-foundation": "node scripts/apply-sentinel-foundation-migration.mjs",
    "db:migrate:auditor-foundation": "node scripts/apply-auditor-foundation-migration.mjs",
    "deploy:firebase": "firebase deploy --only apphosting",
    "firebase:secrets:guide": "node scripts/firebase-secrets-guide.mjs",
    "firebase:secrets:apply": "node scripts/firebase-secrets-guide.mjs --apply"
  },
  "keywords": [
    "nextjs",
    "ia",
    "comunicacao-politica"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "ffmpeg-static": "^5.3.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "form-data": "^4.0.5",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tus-js-client": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "pg": "^8.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
