{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "claude-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "-p", "3100"],
      "port": 3100,
      "autoPort": false
    },
    {
      "name": "start-noauth",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "NEXT_PUBLIC_FIREBASE_API_KEY=",
        "FIREBASE_SERVICE_ACCOUNT_JSON=",
        "FIREBASE_CONFIG=",
        "npm",
        "run",
        "start"
      ],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "dev-noauth",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "NEXT_PUBLIC_FIREBASE_API_KEY=",
        "FIREBASE_SERVICE_ACCOUNT_JSON=",
        "FIREBASE_CONFIG=",
        "npm",
        "run",
        "dev"
      ],
      "port": 3000,
      "autoPort": true
    }
  ]
}
