OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
# Opcional se a chave pertence a org/projeto especifico (evita 401 Not authorized)
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
EVAL_JUDGE_ENABLED=false
EVAL_JUDGE_PROVIDER=
EVAL_JUDGE_MODEL=

# Firebase Auth (login)
# AUTH_DOMAIN deve ser <project-id>.firebaseapp.com (nao a URL da Vercel).
# Google login: Firebase → Authentication → Sign-in method → Google (habilitado).
# Google Cloud → Credentials → Web client (auto created by Firebase) → Authorized redirect URIs:
#   https://<project-id>.firebaseapp.com/__/auth/handler
#   https://<project-id>.web.app/__/auth/handler
# Firebase → Authentication → Settings → Authorized domains: localhost, madatodigital.web.app, madatodigital.firebaseapp.com
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# JSON completo da service account (Project settings → Service accounts → Generate new private key)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Supabase (banco + storage — auth e Firebase)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
# Opcional: chave anon/publica (Settings → API). So necessaria para upload direto <6MB no browser.
# Videos maiores sobem pela API do servidor (service role), sem anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_ANON_KEY=
SUPABASE_TRAINING_ASSETS_BUCKET=persona-training-videos
# No Supabase Dashboard: Storage → Settings → aumente "Global file size limit"
# (Free ate 50 MB; Pro ate 500 GB). Bucket persona-training-videos deve estar alinhado.

# HeyGen (Curador v2 — avatar, voz, video)
HEYGEN_API_KEY=
HEYGEN_BASE_URL=https://api.heygen.com
# Em dev, permite trocar a API key pelo painel oculto do Distribuidor (triplo clique no topo).
# Em producao/staging, defina true apenas se precisar testar outra conta sem redeploy.
HEYGEN_ALLOW_CLIENT_KEY_OVERRIDE=

# Sentinela (Fase 1 — flags opcionais)
# SENTINEL_V2_PIPELINES=true
# SENTINEL_LLM_EXPANSION=true
# SENTINEL_LLM_THEME_VERIFY=true
# Spike qualidade: LLM mini só no top N (off por default; ver docs/spike-sentinela-qualidade.md)
# SENTINEL_LLM_QUALITY_RANK=true
# SENTINEL_TREND_PROXY=true
# SENTINEL_SOCIAL_ENABLED=false
# SENTINEL_SERPAPI_KEY=
# Adversarios: ultimos posts do Instagram via Apify (requer flag + token)
# SENTINEL_SOCIAL_ENABLED=true
# APIFY_TOKEN=
# APIFY_API_TOKEN=
# APIFY_INSTAGRAM_ACTOR_ID=apify/instagram-scraper

# Validador / Fase 2 (flags off em producao ate validacao)
# AUDITOR_FACTCHECK_ENABLED=true
# AUDITOR_V2_REAL_QUEUE=false

# Argil.ai (geracao de video do avatar)
ARGIL_DRY_RUN=true
ARGIL_BASE_URL=https://api.argil.ai/v1
ARGIL_API_KEY=
ARGIL_AVATAR_ID=
ARGIL_VOICE_ID=
ARGIL_ASPECT_RATIO=9:16
ARGIL_SUBTITLES_ENABLED=true

# URL publica do app (HTTPS): treino (assets) + webhook de video pronto (/api/argil/webhooks)
APP_BASE_URL=
NEXT_PUBLIC_APP_BASE_URL=
TRAINING_ASSET_ACCESS_SECRET=

# Compliance / contrato (1ª leva)
# Resend: envio do Contrato + Dossiê após aceite do CNPJ (sem NF nesta fase)
RESEND_API_KEY=
# Temporario: Thiago. Obs: Resend exige dominio verificado no FROM —
# Gmail costuma falhar como remetente ate haver dominio proprio.
EMAIL_FROM=Mandato Digital <tribeiro81@gmail.com>
EMAIL_INTERNAL_COPY=tribeiro81@gmail.com
# Opcional: bucket dedicado; default = SUPABASE_TRAINING_ASSETS_BUCKET
# SUPABASE_COMPLIANCE_BUCKET=
