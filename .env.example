ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
EVAL_JUDGE_ENABLED=false
EVAL_JUDGE_PROVIDER=
EVAL_JUDGE_MODEL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_TRAINING_ASSETS_BUCKET=persona-training-videos
# No Supabase Dashboard: Storage → Settings → aumente "Global file size limit"
# (Free ate 50 MB; Pro ate 500 GB). Bucket persona-training-videos deve estar alinhado.

# Argil.ai (geracao de video do avatar)
ARGIL_DRY_RUN=true
ARGIL_BASE_URL=https://api.argil.ai/v1
ARGIL_API_KEY=
ARGIL_AVATAR_ID=
ARGIL_VOICE_ID=
ARGIL_ASPECT_RATIO=9:16
ARGIL_SUBTITLES_ENABLED=true

# URL publica do app (necessaria para Argil baixar videos de treino via proxy local)
APP_BASE_URL=
TRAINING_ASSET_ACCESS_SECRET=
